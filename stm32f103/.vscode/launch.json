{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "STM32 Debug",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "openocd",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "build-flash",
      "executable": "build/${input:app_name}.elf",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f1x.cfg"
      ],
      "runToEntryPoint": "main",
      "showDevDebugOutput": "raw",
      "gdbPath": "/usr/bin/gdb-multiarch",
    }
  ],
  "inputs": [
    {
      "id": "app_name",
      "type": "promptString",
      "description": "Enter the name of the file to be debugged (e.g., blink, log)",
      "default": "main"
    }
  ]
}